{
  "templateId": "56a81d26-7495-46da-8189-5204b0404562",
  "templateCode": "hitkeep-bucket-template",
  "templateUrl": "https://railway.com/deploy/hitkeep-bucket-template",
  "templateName": "hitkeep-bucket-template",
  "templateStatus": "PUBLISHED",
  "category": "Analytics",
  "description": "Self-hosted HitKeep analytics with Railway Bucket backups.",
  "workspaceId": "ccc9f510-fc82-46d2-a17b-5e82aaf6a413",
  "workspaceName": "liyu's Projects",
  "templateServiceId": "f839469e-8d79-4622-bc41-6315f1c3caa4",
  "templateBucketId": "7eb8c4e4-2866-4a7b-a65d-fb189c07884f",
  "serviceName": "hitkeep",
  "bucketName": "hitkeep-backups",
  "volumeMountPath": "/var/lib/hitkeep/data",
  "backupPath": "s3://${{hitkeep-backups.BUCKET}}/hitkeep/backups",
  "archivePath": "s3://${{hitkeep-backups.BUCKET}}/hitkeep/archive",
  "s3EndpointHost": "t3.storageapi.dev",
  "image": "pascalebeier/hitkeep:2.7.0",
  "preconfiguredVariableCount": 19,
  "preconfiguredVariables": {
    "PORT": "8080",
    "HITKEEP_DB_PATH": "/var/lib/hitkeep/data/hitkeep.db",
    "RAILWAY_RUN_UID": "0",
    "HITKEEP_DATA_PATH": "/var/lib/hitkeep/data",
    "HITKEEP_HTTP_ADDR": ":8080",
    "HITKEEP_S3_REGION": "${{hitkeep-backups.REGION}}",
    "HITKEEP_JWT_SECRET": "${{secret(64, \"abcdef0123456789\")}}",
    "HITKEEP_PUBLIC_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
    "HITKEEP_S3_USE_SSL": "true",
    "HITKEEP_BACKUP_PATH": "s3://${{hitkeep-backups.BUCKET}}/hitkeep/backups",
    "HITKEEP_S3_ENDPOINT": "t3.storageapi.dev",
    "HITKEEP_ARCHIVE_PATH": "s3://${{hitkeep-backups.BUCKET}}/hitkeep/archive",
    "HITKEEP_S3_URL_STYLE": "vhost",
    "HITKEEP_BACKUP_INTERVAL": "60",
    "HITKEEP_BACKUP_RETENTION": "24",
    "HITKEEP_S3_ACCESS_KEY_ID": "${{hitkeep-backups.ACCESS_KEY_ID}}",
    "HITKEEP_SPAM_FILTER_PATH": "/var/lib/hitkeep/data/spam-filter.json",
    "HITKEEP_S3_SECRET_ACCESS_KEY": "${{hitkeep-backups.SECRET_ACCESS_KEY}}",
    "HITKEEP_SPAM_FILTER_AUTO_UPDATE": "true"
  }
}
